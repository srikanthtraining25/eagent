# =============================================================
# Enterprise Agent — Environment Configuration
# =============================================================
# Copy this file to .env and update values for your environment.

# --- Application ---
APP_NAME=enterprise-agent
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- LLM ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
OPENAI_API_KEY=sk-your-api-key-here

# --- Temporal ---
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=enterprise-agent
TEMPORAL_WORKFLOW_EXECUTION_TIMEOUT=300
TEMPORAL_ACTIVITY_START_TO_CLOSE_TIMEOUT=120
TEMPORAL_ACTIVITY_RETRY_MAX_ATTEMPTS=3

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# --- PostgreSQL (Temporal backend) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=temporal
POSTGRES_USER=temporal
POSTGRES_PASSWORD=temporal

# --- FastA2A ---
A2A_AGENT_NAME=enterprise-agent
A2A_AGENT_DESCRIPTION=Enterprise AI Agent — handles KB queries, actions, and delegations
A2A_AGENT_VERSION=1.0.0
A2A_BASE_URL=http://localhost:8000

# --- A2A Client (Outbound) ---
A2A_CLIENT_TIMEOUT=30
A2A_CLIENT_MAX_RETRIES=3

# --- Agent Registry (External Agents) ---
A2A_EXTERNAL_AGENT_URLS=

# --- RAG / Knowledge Base ---
KB_COLLECTION_NAME=enterprise_kb
KB_EMBEDDING_MODEL=text-embedding-3-small
KB_CHUNK_SIZE=1000
KB_CHUNK_OVERLAP=200
KB_TOP_K=5

# --- Observability ---
OTEL_ENABLED=true
OTEL_SERVICE_NAME=enterprise-agent
OTEL_EXPORTER_ENDPOINT=http://localhost:6006
PHOENIX_ENABLED=true
PHOENIX_PROJECT_NAME=enterprise-agent
